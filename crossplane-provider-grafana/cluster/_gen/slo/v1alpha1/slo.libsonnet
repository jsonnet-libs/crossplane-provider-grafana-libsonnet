          '#withMinFailures':: d.fn(help='"(Number) Minimum number of failed events to trigger an alert\\nMinimum number of failed events to trigger an alert"', args=[d.arg(name='minFailures', type=d.T.number)]),
          withMinFailures(minFailures): { minFailures: minFailures },
        },
        '#annotation':: d.obj(help='"(Block List) Annotations will be attached to all alerts generated by any of these rules. (see below for nested schema)\\nAnnotations will be attached to all alerts generated by any of these rules."'),
